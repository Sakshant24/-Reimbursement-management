generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id              String   @id @default(uuid())
  name            String
  country         String
  defaultCurrency String
  users           User[]
  rules           ApprovalRule[]
  expenses        Expense[]
  createdAt       DateTime @default(now())
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       Role     @default(EMPLOYEE)
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])
  managerId  String?
  manager    User?    @relation("ManagerEmployee", fields: [managerId], references: [id])
  subordinates User[] @relation("ManagerEmployee")
  expenses   Expense[]
  approvals  Approval[]
  createdAt  DateTime @default(now())

  @@index([companyId])
  @@index([managerId])
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

model Expense {
  id               String        @id @default(uuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  companyId        String
  company          Company       @relation(fields: [companyId], references: [id])
  amount           Decimal       @db.Decimal(12, 2)
  currency         String
  convertedAmount  Decimal       @db.Decimal(12, 2)
  exchangeRate     Decimal       @db.Decimal(10, 6)
  category         ExpenseCategory
  description      String        @db.Text
  date             DateTime
  receiptPath      String?
  ocrRawText       String?       @db.Text
  status           ExpenseStatus @default(PENDING)
  currentStep      Int           @default(1)
  ruleId           String?
  rule             ApprovalRule? @relation(fields: [ruleId], references: [id])
  approvals        Approval[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([status])
}

enum ExpenseStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum ExpenseCategory {
  TRAVEL
  FOOD
  ACCOMMODATION
  OFFICE_SUPPLIES
  CONFERENCE
  OTHER
}

model Approval {
  id             String         @id @default(uuid())
  expenseId      String
  expense        Expense        @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  approverId     String
  approver       User           @relation(fields: [approverId], references: [id])
  stepOrder      Int
  isManagerStep  Boolean        @default(false)
  status         ApprovalStatus @default(PENDING)
  comments       String?        @db.Text
  respondedAt    DateTime?
  createdAt      DateTime       @default(now())

  @@unique([expenseId, stepOrder])
  @@index([approverId])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model ApprovalRule {
  id                   String    @id @default(uuid())
  companyId            String
  company              Company   @relation(fields: [companyId], references: [id])
  name                 String
  categoryFilter       ExpenseCategory?
  isManagerFirst       Boolean   @default(true)
  ruleType             RuleType
  thresholdPercentage  Decimal?  @db.Decimal(5, 2)
  specificApproverId   String?
  approverSequence     Json
  expenses             Expense[]
  createdAt            DateTime  @default(now())
}

enum RuleType {
  SEQUENTIAL
  PERCENTAGE
  SPECIFIC
  HYBRID
}
